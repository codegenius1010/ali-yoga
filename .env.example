# Environment Variables Template
# Copy this file to .env.local and fill in with your actual values
# NEVER commit .env.local - it contains sensitive data

# ============================================
# PUBLIC VARIABLES (Safe to expose in browser)
# ============================================

# Site URL for canonical links and metadata
NEXT_PUBLIC_SITE_URL=https://aliyoga.com

# Google Analytics 4 Measurement ID
# Get from https://analytics.google.com
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ============================================
# PRIVATE VARIABLES (Server-side only)
# ============================================

# Email Service Configuration
# Recommended: SendGrid (https://sendgrid.com)
# Alternative: Mailgun, AWS SES, Postmark

# SendGrid API Key (get from SendGrid dashboard)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email address for booking form notifications to come from
SENDGRID_FROM_EMAIL=noreply@aliyoga.com

# Email address where booking form submissions are sent
# Typically your business email
FORM_NOTIFICATION_EMAIL=ali@aliyoga.com

# ============================================
# OPTIONAL: Payment Processing (If needed)
# ============================================

# Stripe Keys (https://stripe.com)
# Public key can be exposed to browser
# Secret key must be kept private
# NEXT_PUBLIC_STRIPE_PUBLIC_KEY=your_stripe_public_key
# STRIPE_SECRET_KEY=your_stripe_secret_key

# ============================================
# OPTIONAL: Database (If adding backend)
# ============================================

# Database URL for storing data
# Example formats:
# PostgreSQL: postgresql://user:password@localhost:5432/aliyoga
# MongoDB: mongodb+srv://user:password@cluster.mongodb.net/aliyoga
DATABASE_URL=postgresql://user:password@localhost:5432/aliyoga

# ============================================
# OPTIONAL: Authentication
# ============================================

# NextAuth Secret (if using NextAuth.js)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_secret_here_change_in_production

# NextAuth URL (for authentication callbacks)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_URL_INTERNAL=http://localhost:3000

# ============================================
# OPTIONAL: Content Management
# ============================================

# Contentful (if using Contentful CMS)
CONTENTFUL_SPACE_ID=your_space_id
CONTENTFUL_ACCESS_TOKEN=your_access_token
CONTENTFUL_PREVIEW_TOKEN=your_preview_token

# Sanity (if using Sanity CMS)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your_api_token

# ============================================
# OPTIONAL: Third-party Services
# ============================================

# Calendly Integration (for scheduling)
CALENDLY_API_TOKEN=your_token_here

# Zapier Integration (for automation)
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/...

# Slack Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ============================================
# NOTES
# ============================================

# How to set up for local development:
# 1. Copy .env.example to .env.local
# 2. Fill in required variables (marked with *)
# 3. For tests, use development/test keys from services
# 4. Never commit .env.local to git

# How to deploy to Vercel:
# 1. Go to Vercel project settings
# 2. Environment Variables section
# 3. Add each variable from .env.local
# 4. Vercel will use these for production builds
# 5. Use different keys for production vs staging

# Where to get each value:
# - NEXT_PUBLIC_GA_ID: https://analytics.google.com > Admin > Property Settings
# - SENDGRID_API_KEY: https://app.sendgrid.com > Settings > API Keys
# - STRIPE_KEYS: https://dashboard.stripe.com > API Keys
# - DATABASE_URL: From your database provider (Heroku, PlanetScale, etc)
# - NEXTAUTH_SECRET: Run `openssl rand -base64 32` in terminal

# Security checklist:
# ✅ Never put real API keys in this file after copying
# ✅ Add .env.local to .gitignore (already done)
# ✅ Use environment variables for all secrets
# ✅ Rotate API keys periodically
# ✅ Use different keys for dev/staging/production
# ✅ Review .env.local before committing (just in case)